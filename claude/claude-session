#!/usr/bin/env zsh

# Claude session management script with robust Zellij integration
set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

# Paths
CLAUDE_DIR=~/.claude
SESSIONS_DIR="$CLAUDE_DIR/sessions"
METADATA_DIR="$CLAUDE_DIR/metadata"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Ensure directories exist
mkdir -p "$SESSIONS_DIR" "$METADATA_DIR"

# Check dependencies
check_dependencies() {
    local missing=()
    
    # Check for required commands
    for cmd in zellij jq claude; do
        if ! command -v "$cmd" >/dev/null 2>&1; then
            missing+=("$cmd")
        fi
    done
    
    if [[ ${#missing[@]} -gt 0 ]]; then
        echo -e "${RED}Error: Missing required dependencies:${RESET}"
        for cmd in "${missing[@]}"; do
            echo -e "  - ${YELLOW}$cmd${RESET}"
        done
        echo ""
        echo "Please install missing dependencies and try again."
        exit 1
    fi
}

# Run dependency check
check_dependencies

# Function to generate random Docker-style names
generate_random_name() {
    local adjectives=("admiring" "adoring" "agitated" "amazing" "angry" "awesome" "beautiful" "blissful" "bold" "brave" "busy" "charming" "clever" "cool" "compassionate" "confident" "creative" "dazzling" "determined" "eager" "elastic" "elegant" "epic" "exciting" "fervent" "festive" "focused" "friendly" "frosty" "funny" "gallant" "gifted" "gracious" "happy" "hopeful" "inspiring" "intelligent" "jolly" "jovial" "keen" "kind" "laughing" "loving" "lucid" "magical" "modest" "mystifying" "naughty" "nice" "nifty" "objective" "optimistic" "peaceful" "pensive" "practical" "priceless" "quirky" "relaxed" "reverent" "romantic" "serene" "sharp" "silly" "sleepy" "stoic" "strange" "sweet" "tender" "trusting" "vibrant" "vigilant" "vigorous" "wizardly" "wonderful" "xenial" "youthful" "zealous" "zen")
    local nouns=("allen" "archimedes" "austin" "babbage" "banach" "bell" "benz" "bohr" "booth" "borg" "bose" "boyd" "brown" "buck" "carson" "cerf" "clarke" "cohen" "cori" "cray" "curie" "darwin" "diffie" "dijkstra" "dirac" "edison" "einstein" "elion" "ellis" "euclid" "euler" "faraday" "fermat" "fermi" "feynman" "franklin" "galileo" "gates" "gauss" "gould" "hamilton" "hawking" "heisenberg" "hermann" "hopper" "hubble" "hypatia" "jackson" "jang" "jennings" "jepsen" "johnson" "jones" "kalam" "kare" "keller" "kepler" "kilby" "kirch" "knuth" "lamport" "leakey" "leavitt" "lovelace" "lumiere" "mahavira" "mayer" "mccarthy" "mclean" "mendel" "meitner" "merkle" "moore" "morse" "murdock" "napier" "nash" "neumann" "newton" "nobel" "noyce" "panini" "pare" "pascal" "pasteur" "payne" "pike" "planck" "ptolemy" "raman" "ride" "ritchie" "rhodes" "robinson" "rosalind" "rubin" "saha" "sammet" "shannon" "shaw" "shirley" "shockley" "solomon" "spence" "stallman" "swartz" "tesla" "thompson" "torvalds" "turing" "varahamihira" "vaughan" "villani" "volhard" "wescoff" "wilbur" "wiles" "williams" "wilson" "wing" "wozniak" "wright" "wu" "yalow" "yonath")
    
    local adj=${adjectives[$RANDOM % ${#adjectives[@]}]}
