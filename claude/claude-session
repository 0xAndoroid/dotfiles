    echo "${adj}-${noun}"
}

# Function to get all Claude sessions
get_sessions() {
    local sessions=()
    if command -v zellij >/dev/null 2>&1; then
        # Get zellij sessions that match our pattern
        while IFS= read -r session; do
            if [[ "$session" =~ ^claude-session- ]]; then
                sessions+=("$session")
            fi
        done < <(zellij list-sessions 2>/dev/null | grep -E '^claude-session-' || true)
    fi
    echo "${sessions[@]}"
}

# Function to get session info
get_session_info() {
    local session_id="$1"
    local metadata_file="$METADATA_DIR/${session_id}.json"
    if [[ -f "$metadata_file" ]]; then
        cat "$metadata_file"
    else
        echo "{}"
    fi
}

# Function to save session metadata
save_session_metadata() {
    local session_id="$1"
    local name="$2"
    local session_file="$3"
    local metadata_file="$METADATA_DIR/${session_id}.json"
    
    cat > "$metadata_file" << EOF
{
    "session_id": "$session_id",
    "name": "$name",
    "session_file": "$session_file",
    "created_at": "$(date -Iseconds)",
    "last_accessed": "$(date -Iseconds)",
    "status": "active"
}
EOF
}

# Function to update session access time
update_session_access() {
    local session_id="$1"
    local metadata_file="$METADATA_DIR/${session_id}.json"
    if [[ -f "$metadata_file" ]]; then
        local content=$(cat "$metadata_file")
        echo "$content" | jq --arg time "$(date -Iseconds)" '.last_accessed = $time' > "${metadata_file}.tmp"
        mv "${metadata_file}.tmp" "$metadata_file"
    fi
}

# Function to list sessions
list_sessions() {
    echo -e "${BOLD}${CYAN}Active Claude Sessions:${RESET}"
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
    
    local sessions=($(get_sessions))
    if [[ ${#sessions[@]} -eq 0 ]]; then
        echo -e "${YELLOW}No active sessions found.${RESET}"
        return
    fi
    
    for session in "${sessions[@]}"; do
        local metadata=$(get_session_info "$session")
        local name=$(echo "$metadata" | jq -r '.name // "unknown"')
        local created=$(echo "$metadata" | jq -r '.created_at // "unknown"')
        local accessed=$(echo "$metadata" | jq -r '.last_accessed // "unknown"')
        
        echo -e "${GREEN}Session:${RESET} $name"
        echo -e "  ${BLUE}ID:${RESET} $session"
        echo -e "  ${BLUE}Created:${RESET} $created"
        echo -e "  ${BLUE}Last accessed:${RESET} $accessed"
        
        # Check if session is actually running
        if zellij list-sessions 2>/dev/null | grep -q "^$session"; then
            echo -e "  ${GREEN}Status:${RESET} Running"
        else
            echo -e "  ${RED}Status:${RESET} Stopped"
        fi
        echo ""
    done
}

# Function to attach to session
attach_session() {
    local session_name="$1"
    local session_id=""
    
    # Find session ID by name
    local sessions=($(get_sessions))
    for session in "${sessions[@]}"; do
        local metadata=$(get_session_info "$session")
        local name=$(echo "$metadata" | jq -r '.name // ""')
        if [[ "$name" == "$session_name" ]]; then
            session_id="$session"
            break
        fi
    done
    
    if [[ -z "$session_id" ]]; then
        echo -e "${RED}Error: Session '$session_name' not found${RESET}"
        echo -e "${YELLOW}Available sessions:${RESET}"
        list_sessions
        return 1
    fi
    
    # Update access time
    update_session_access "$session_id"
    
    # Attach to zellij session
    echo -e "${GREEN}Attaching to session '$session_name'...${RESET}"
    zellij attach "$session_id"
}

# Function to create new session
create_session() {
    local session_name="$1"
    local timestamp=$(date +%Y%m%d_%H%M%S)
    local session_id="claude-session-${timestamp}"
    local session_file="$SESSIONS_DIR/${session_name}_${timestamp}.txt"
    
    # Save metadata
    save_session_metadata "$session_id" "$session_name" "$session_file"
    
    # Use local CLAUDE.md in current directory
    local claude_md_path="./CLAUDE.md"
    local claude_md_backup=""
    local claude_md_created=false
    
    # Check if local CLAUDE.md exists, if not create it
    if [[ -f "$claude_md_path" ]]; then
        # Backup existing local CLAUDE.md
        claude_md_backup=$(mktemp)
        cp "$claude_md_path" "$claude_md_backup"
    else
        # Create new local CLAUDE.md
        claude_md_created=true
        touch "$claude_md_path"
    fi
    
    # Function to cleanup on exit
    cleanup() {
        if [[ "$claude_md_created" == "true" ]]; then
            # We created the file, so remove it
            rm -f "$claude_md_path"
        elif [[ -n "$claude_md_backup" && -f "$claude_md_backup" ]]; then
            # Restore original content
            cp "$claude_md_backup" "$claude_md_path"
            rm -f "$claude_md_backup"
        fi
        
        # Update session status
        local metadata_file="$METADATA_DIR/${session_id}.json"
        if [[ -f "$metadata_file" ]]; then
            local content=$(cat "$metadata_file")
            echo "$content" | jq '.status = "stopped"' > "${metadata_file}.tmp"
            mv "${metadata_file}.tmp" "$metadata_file"
        fi
    }
    
    # Set up cleanup on exit
    trap cleanup EXIT INT TERM
    
    # Add monitoring instructions to CLAUDE.md
    cat >> "$claude_md_path" << EOF

# Session Monitoring Instructions

**============ MAJOR DECISION ============**
IMPORTANT: During this session, you must log important events to the session file.
**============ MAJOR DECISION ============**

When you make a major architectural decision or decide to try a new approach, use the claude-report script to log it.
When you reach a milestone in the process, also use claude-report to log it.

Use the Bash tool to run claude-report:
\`\`\`bash
# For decisions:
claude-report -t decision -i high -d "Decided to use async architecture" -s $session_file

# For milestones:
claude-report -t milestone -i low -d "Completed initial setup" -s $session_file
\`\`\`

The script will automatically generate the timestamp and create properly formatted JSON.

Session file path: $session_file
EOF
    
    # Create the monitoring script path (absolute)
    local monitor_script="$SCRIPT_DIR/claude-monitor"
    
    # Create a temporary layout file with .kdl extension
    local layout_file=$(mktemp -t zellij-layout.XXXXXX.kdl)
    
    cat > "$layout_file" << EOF
layout {
    pane split_direction="vertical" {
        pane size="70%" {
            command "claude"
        }
        pane {
            command "$monitor_script"
            args "$session_file"
        }
    }
}
EOF
    
    # Start zellij with the layout
    echo -e "${GREEN}Starting new session '$session_name'...${RESET}"
    zellij --session "$session_id" --layout "$layout_file"
    
    # Clean up layout file if it still exists
    [[ -f "$layout_file" ]] && rm -f "$layout_file"
}

# Function to kill session
kill_session() {
    local session_name="$1"
    local session_id=""
    
    # Find session ID by name
    local sessions=($(get_sessions))
    for session in "${sessions[@]}"; do
        local metadata=$(get_session_info "$session")
        local name=$(echo "$metadata" | jq -r '.name // ""')
        if [[ "$name" == "$session_name" ]]; then
            session_id="$session"
            break
        fi
    done
    
    if [[ -z "$session_id" ]]; then
        echo -e "${RED}Error: Session '$session_name' not found${RESET}"
        return 1
    fi
    
    # Kill zellij session
    echo -e "${YELLOW}Killing session '$session_name'...${RESET}"
    zellij kill-session "$session_id" 2>/dev/null || true
    
    # Update metadata
    local metadata_file="$METADATA_DIR/${session_id}.json"
    if [[ -f "$metadata_file" ]]; then
        local content=$(cat "$metadata_file")
        echo "$content" | jq '.status = "killed"' > "${metadata_file}.tmp"
        mv "${metadata_file}.tmp" "$metadata_file"
    fi
    
    echo -e "${GREEN}Session killed successfully.${RESET}"
}

# Function to clean up old sessions
cleanup_sessions() {
    local days="${1:-7}"
    echo -e "${YELLOW}Cleaning up sessions older than $days days...${RESET}"
    
    # Clean up old session files
    find "$SESSIONS_DIR" -name "*.txt" -mtime +$days -delete 2>/dev/null || true
    
    # Clean up orphaned metadata
    for metadata_file in "$METADATA_DIR"/*.json; do
        [[ -f "$metadata_file" ]] || continue
        local session_id=$(basename "$metadata_file" .json)
        if ! zellij list-sessions 2>/dev/null | grep -q "^$session_id"; then
            local created=$(jq -r '.created_at' "$metadata_file" 2>/dev/null || echo "")
            if [[ -n "$created" ]]; then
                local created_timestamp=$(date -jf "%Y-%m-%dT%H:%M:%S" "${created%%.*}" +%s 2>/dev/null || echo 0)
                local current_timestamp=$(date +%s)
                local age_days=$(( (current_timestamp - created_timestamp) / 86400 ))
                if [[ $age_days -gt $days ]]; then
                    rm -f "$metadata_file"
                    echo -e "${GREEN}Cleaned up metadata for $session_id${RESET}"
                fi
            fi
        fi
    done
}

# Main command handling
case "${1:-}" in
    "list"|"ls")
        list_sessions
        ;;
    "attach"|"a")
        if [[ -z "${2:-}" ]]; then
            echo -e "${RED}Error: Session name required${RESET}"
            echo "Usage: $0 attach <session-name>"
            exit 1
        fi
        attach_session "$2"
        ;;
    "kill"|"k")
        if [[ -z "${2:-}" ]]; then
            echo -e "${RED}Error: Session name required${RESET}"
            echo "Usage: $0 kill <session-name>"
            exit 1
        fi
        kill_session "$2"
        ;;
    "cleanup")
        cleanup_sessions "${2:-7}"
        ;;
    "help"|"-h"|"--help")
        echo "Claude Session Manager"
        echo ""
        echo "Usage: $0 [command] [options]"
        echo ""
        echo "Commands:"
        echo "  <name>          Start new session with given name (or random if not provided)"
        echo "  list, ls        List all active sessions"
        echo "  attach, a       Attach to existing session"
        echo "  kill, k         Kill a session"
        echo "  cleanup [days]  Clean up sessions older than N days (default: 7)"
        echo "  help            Show this help message"
        echo ""
        echo "Examples:"
        echo "  $0                    # Start session with random name"
        echo "  $0 my-project         # Start session named 'my-project'"
        echo "  $0 attach my-project  # Attach to existing session"
        echo "  $0 list               # List all sessions"
        ;;
    *)
        # Create new session
        session_name="${1:-$(generate_random_name)}"
        
        # Check if session already exists
        local sessions=($(get_sessions))
        for session in "${sessions[@]}"; do
            local metadata=$(get_session_info "$session")
            local name=$(echo "$metadata" | jq -r '.name // ""')
            if [[ "$name" == "$session_name" ]]; then
                echo -e "${YELLOW}Session '$session_name' already exists.${RESET}"
                echo -e "${CYAN}Would you like to attach to it? (y/n)${RESET}"
                read -r response
                if [[ "$response" =~ ^[Yy]$ ]]; then
                    attach_session "$session_name"
                    exit 0
                else
                    echo -e "${RED}Aborted.${RESET}"
                    exit 1
                fi
            fi
        done
        
        create_session "$session_name"
        ;;
esac