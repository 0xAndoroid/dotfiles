{
  "env": {
    "ANTHROPIC_MODEL": "claude-opus-4-8[1m]",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_FEEDBACK_COMMAND": "1",
    "DISABLE_TELEMETRY": "1",
    "ENABLE_CLAUDEAI_MCP_SERVERS": "false",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "sonnet",
    "CLAUDE_CODE_SUBAGENT_MODEL": "opus",
    "TASK_MAX_OUTPUT_LENGTH": "64000",
    "CLAUDE_CODE_NO_FLICKER": "1"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash",
      "Edit",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:docs.rs)",
      "WebFetch(domain:crates.io)",
      "WebFetch(domain:npmjs.com)",
      "WebFetch(domain:pypi.org)",
      "WebFetch(domain:stackoverflow.com)",
      "WebFetch(domain:rust-lang.org)",
      "WebFetch(domain:python.org)",
      "WebFetch(domain:nodejs.org)",
      "WebFetch(domain:developer.mozilla.org)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(su:*)",
      "Bash(chmod 777:*)",
      "Bash(git credential:*)",
      "Bash(git config:*)",
      "Bash(gh auth:*)",
      "Bash(gh secret:*)",
      "Bash(gh ssh-key:*)",
      "Bash(gh gpg-key:*)",
      "Bash(gh codespace:*)",
      "Bash(gh org:*)",
      "Bash(gh config set:*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Bash(rsync:*)",
      "Bash(apt:*)",
      "Bash(yum:*)",
      "Bash(systemctl:*)",
      "Bash(service:*)",
      "Bash(killall:*)",
      "Bash(reboot:*)",
      "Bash(shutdown:*)",
      "Bash(passwd:*)",
      "Bash(useradd:*)",
      "Bash(userdel:*)",
      "Bash(groupadd:*)",
      "Bash(nc:*)",
      "Bash(netcat:*)",
      "Bash(telnet:*)",
      "Bash(ftp:*)",
      "Edit(~/.ssh/**)",
      "Edit(~/.keysrc)",
      "Edit(~/.aws/**)",
      "Edit(~/.config/gh/**)",
      "Edit(/etc/**)",
      "Edit(/sys/**)",
      "Edit(/proc/**)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.keysrc)",
      "Read(**/.env)",
      "Read(**/secrets/**)",
      "Read(**/credentials/**)"
    ]
  },
  "model": "claude-opus-4-6[1m]",
  "enableAllProjectMcpServers": true,
  "statusLine": {
    "type": "command",
    "command": "~/.dotfiles/claude/statusline.sh"
  },
  "enabledPlugins": {
    "worktrunk@worktrunk": true,
    "skill-creator@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {},
  "forceLoginMethod": "claudeai",
  "alwaysThinkingEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "preferredNotifChannel": "ghostty",
  "autoCompactEnabled": false,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${HOME}/.dotfiles/claude/hooks/enforce-uv.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
